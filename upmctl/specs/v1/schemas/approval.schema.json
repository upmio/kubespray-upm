{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://upm.io/schemas/upmctl/v1alpha1/approval.schema.json",
  "title": "upmctl immutable human approval",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "approvalId",
    "approvalDigest",
    "decision",
    "planId",
    "planDigest",
    "environmentId",
    "action",
    "target",
    "riskLevel",
    "approvalScope",
    "basis",
    "policyVersion",
    "approvedAt",
    "expiresAt",
    "approver",
    "humanPresence",
    "reason",
    "requestId",
    "cliVersion"
  ],
  "properties": {
    "apiVersion": { "const": "upmctl.upm.io/v1alpha1" },
    "kind": { "const": "Approval" },
    "approvalId": { "type": "string", "pattern": "^approval-[0-9a-f]{64}$" },
    "approvalDigest": { "$ref": "#/$defs/digest" },
    "decision": { "const": "APPROVED" },
    "planId": { "type": "string", "pattern": "^plan-[0-9a-f]{64}$" },
    "planDigest": { "$ref": "#/$defs/digest" },
    "environmentId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "action": { "const": "vm.start" },
    "target": { "$ref": "#/$defs/target" },
    "riskLevel": { "enum": ["R1", "R2", "R3"] },
    "approvalScope": { "type": "string", "pattern": "^vm\\.start:k8s-[1-8]$" },
    "basis": { "$ref": "#/$defs/basis" },
    "policyVersion": { "const": "human-approval-v1" },
    "approvedAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "approver": { "$ref": "#/$defs/approver" },
    "humanPresence": { "$ref": "#/$defs/humanPresence" },
    "reason": { "type": "string", "minLength": 1, "maxLength": 1024 },
    "requestId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "cliVersion": { "type": "string", "minLength": 1, "maxLength": 128 }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "target": {
      "type": "object",
      "required": ["kind", "name"],
      "properties": {
        "kind": { "const": "VirtualMachine" },
        "name": { "type": "string", "pattern": "^k8s-[1-8]$" }
      },
      "additionalProperties": false
    },
    "basis": {
      "type": "object",
      "required": ["configDigest", "managedStateDigest", "observedStateDigest"],
      "properties": {
        "configDigest": { "$ref": "#/$defs/digest" },
        "managedStateDigest": { "$ref": "#/$defs/digest" },
        "observedStateDigest": { "$ref": "#/$defs/digest" }
      },
      "additionalProperties": false
    },
    "approver": {
      "type": "object",
      "required": ["subject", "uid", "username", "hostname", "source", "authMethod"],
      "properties": {
        "subject": { "type": "string", "minLength": 1, "maxLength": 256 },
        "uid": { "type": "string", "minLength": 1, "maxLength": 128 },
        "username": { "type": "string", "minLength": 1, "maxLength": 128 },
        "hostname": { "type": "string", "minLength": 1, "maxLength": 255 },
        "source": { "const": "human-cli" },
        "authMethod": { "const": "interactive-tty" }
      },
      "additionalProperties": false
    },
    "humanPresence": {
      "type": "object",
      "required": ["method", "terminal", "challengeDigest", "confirmedAt"],
      "properties": {
        "method": { "const": "typed-challenge" },
        "terminal": { "type": "string", "minLength": 1, "maxLength": 256 },
        "challengeDigest": { "$ref": "#/$defs/digest" },
        "confirmedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
